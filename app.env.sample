# Zammad - app.env.sample
# Copy to app.env and adjust values before starting

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# Database credentials
DB_CREATE_DATABASE_NAME=zammad_production
DB_USER_NAME=zammad
DB_USER_PASS=changeme_db_password

# Elasticsearch password
ELASTICSEARCH_PASSWORD=changeme_db_password

# Optional Zammad tuning (leave blank for defaults)
ZAMMAD_WEB_CONCURRENCY=
ZAMMAD_SESSION_JOBS=
ZAMMAD_PROCESS_SCHEDULED=
ZAMMAD_PROCESS_DELAYED_JOBS_WORKERS=
ZAMMAD_NGINX_SCHEME=http
ZAMMAD_RAILS_TRUSTED_PROXIES=
